local function encodeMsg(msg)
    -- تحويل الرسالة لـ base-like مخفي
    local encoded=""
    for i=1,#msg do
        encoded=encoded..string.char(string.byte(msg,i)+1)
    end
    return encoded
end
local function decodeMsg(msg)
    local decoded=""
    for i=1,#msg do
        local b=string.byte(msg,i)-1
        if b>=32 and b<=126 then
            decoded=decoded..string.char(b)
        else
            return nil
        end
    end
    return decoded
end


-- نظام السحب المحسن
local dragStart=nil
local btnStartPos=nil
local wasDragged=false

local function onDragStart(pos)
    dragStart=pos
    btnStartPos=DragBtn.Position
    wasDragged=false
end

local function onDragMove(pos)
    if not dragStart then return end
    local delta=pos-dragStart
    if delta.Magnitude>10 then
        wasDragged=true
        local sc=game:GetService("GuiService"):GetScreenResolution()
        local nx=math.clamp(btnStartPos.X.Offset+delta.X,0,sc.X-58)
        local ny=math.clamp(btnStartPos.Y.Offset+delta.Y,0,sc.Y-58)
        DragBtn.Position=UDim2.new(0,nx,0,ny)
    end
end

local function onDragEnd()
    if not wasDragged then
        Main.Visible=not Main.Visible
    end
    dragStart=nil
    wasDragged=false
end

-- موبايل
DragBtn.TouchStarted:Connect(function(touch)
    onDragStart(Vector2.new(touch.Position.X,touch.Position.Y))
end)
DragBtn.TouchMoved:Connect(function(touch)
    onDragMove(Vector2.new(touch.Position.X,touch.Position.Y))
end)
DragBtn.TouchEnded:Connect(function()
    onDragEnd()
end)

-- كمبيوتر
DragBtn.MouseButton1Down:Connect(function()
    local mp=UIS:GetMouseLocation()
    onDragStart(mp)
end)
UIS.InputChanged:Connect(function(input)
    if dragStart and input.UserInputType==Enum.UserInputType.MouseMovement then
        onDragMove(UIS:GetMouseLocation())
    end
end)
UIS.InputEnded:Connect(function(input)
    if input.UserInputType==Enum.UserInputType.MouseButton1 and dragStart then
        onDragEnd()
    end
end)

UIS.InputBegan:Connect(function(input,gp)
    if gp then return end
    if input.KeyCode==Enum.KeyCode.B then Main.Visible=not Main.Visible end
end)


local currentAnim=nil
local function PlayAnim(id)
    local h=GH();if not h then return end
    if currentAnim then SC(function() currentAnim:Stop() end) end
    local anim=Instance.new("Animation")
    anim.AnimationId="rbxassetid://"..tostring(id)
    SC(function()
        currentAnim=h:LoadAnimation(anim)
        currentAnim:Play()
        currentAnim.Looped=true
    end)
    N("انميشن","مفعل")
end


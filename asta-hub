                nameBtn.TextColor3=Color3.fromRGB(255,255,100)
            end)
            nameBtn.MouseLeave:Connect(function()
                nameBtn.TextColor3=Color3.new(1,1,1)
            end)
        end
    end

    task.wait()
    MsgScroll.CanvasPosition=Vector2.new(0,MsgLayout.AbsoluteContentSize.Y+999)
end

-- إرسال
local function SendMsg()
    local text=InputBox.Text
    if text=="" then return end
    InputBox.Text=""

    if chatMode=="private" and pmTarget then
        -- إرسال الخاص كمسافات غير مرئية
        local encoded=encodePM(pmTarget,text)
        sendMsg(encoded)
        AddMsg(LP.Name,text,"private",pmTarget)
        table.insert(myPM,{from=LP.Name,to=pmTarget,text=text})
        table.insert(allPM,{from=LP.Name,to=pmTarget,text=text})
    else
        sendMsg(text)
        AddMsg(LP.Name,text,"public")
        table.insert(pubMsgs,{from=LP.Name,text=text})
    end
end

InputBox.FocusLost:Connect(function(enter) if enter then SendMsg() end end)

-- استقبال رسائل
local function handleMsg(p,msg)
    local to,pmsg=decodePM(msg)
    if to and pmsg then
        -- رسالة خاصة مشفرة
        if to==LP.Name then
            -- مرسلة لي
            table.insert(myPM,{from=p.Name,to=LP.Name,text=pmsg})
            table.insert(allPM,{from=p.Name,to=LP.Name,text=pmsg})
            AddMsg(p.Name,pmsg,"private",LP.Name)
            if not Main.Visible then N("🔒 "..p.Name,pmsg,5) end
        elseif isOwner or isSubscribed(LP.Name) then
            -- المشترك والأونر يشوفون كل الخاص
            table.insert(allPM,{from=p.Name,to=to,text=pmsg})
            AddMsg(p.Name,pmsg,"private",to)
        end
        -- باقي الناس ما يشوفون أي شي ✅
    else
        -- رسالة عامة
        table.insert(pubMsgs,{from=p.Name,text=msg})
        AddMsg(p.Name,msg,"public")
    end
end

for _,p in ipairs(Players:GetPlayers()) do
    if p~=LP then
        p.Chatted:Connect(function(msg) handleMsg(p,msg) end)
    end
end


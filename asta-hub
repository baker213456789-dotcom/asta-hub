local function UpdatePlayers()
    for _,c in ipairs(PlayersList:GetChildren()) do
        if not c:IsA("UIListLayout") then c:Destroy() end
    end
    local count=0
    for _,p in ipairs(Players:GetPlayers()) do
        if p~=LP and activeUsers[p.Name] then
            count=count+1
            local btn=Instance.new("TextButton",PlayersList)
            btn.Size=UDim2.new(1,-4,0,30)
            btn.BackgroundColor3=Color3.fromRGB(18,18,28)
            btn.BorderSizePixel=0
            Instance.new("UICorner",btn).CornerRadius=UDim.new(0,6)
            Instance.new("UIStroke",btn).Color=Color3.fromRGB(0,200,80)
            local subIcon=subscribers[p.Name] and "⭐ " or "🟢 "
            btn.Text="  "..subIcon..p.Name
            btn.TextSize=11
            btn.Font=Enum.Font.GothamBold
            btn.TextColor3=Color3.fromRGB(255,200,0)
            btn.TextXAlignment=Enum.TextXAlignment.Right

            btn.MouseButton1Click:Connect(function()
                privateTarget=p.Name
                chatMode="private"
                PlayersList.Visible=false
                MsgScroll.Visible=true
                InputBox.PlaceholderText="...خاص مع "..p.Name.." 🔒"
                PrivateTab.BackgroundColor3=Color3.fromRGB(0,200,255)
                PrivateTab.TextColor3=Color3.new(0,0,0)
                PublicTab.BackgroundColor3=Color3.fromRGB(25,25,35)
                PublicTab.TextColor3=Color3.fromRGB(150,150,150)
                for _,c2 in ipairs(MsgScroll:GetChildren()) do
                    if not c2:IsA("UIListLayout") then c2:Destroy() end
                end
                msgCount=0
                local msgsToShow=(isOwner or subscribers[LP.Name]) and allPrivateMsgs or myPrivateMsgs
                for _,msg in ipairs(msgsToShow) do
                    if (msg.from==p.Name and msg.to==LP.Name) or (msg.from==LP.Name and msg.to==p.Name) then
                        AddMsg(msg.from,msg.text,"private")
                    end
                end
                AddMsg("النظام","محادثة خاصة مع "..p.Name.." 🔒","system")
                N("خاص","فتحت محادثة مع "..p.Name)
            end)
        end
    end
    -- إذا ما فيه أحد عنده السكربت
    if count==0 then
        local lbl=Instance.new("TextLabel",PlayersList)
        lbl.Size=UDim2.new(1,0,0,40)
        lbl.BackgroundTransparency=1
        lbl.TextColor3=Color3.fromRGB(150,150,150)
        lbl.Text="لا يوجد لاعبين يستخدمون ASTA CHAT"
        lbl.TextSize=11
        lbl.Font=Enum.Font.Gotham
        lbl.TextWrapped=true
    end
end


-- إرسال رسالة
local function SendMsg()
    local text=InputBox.Text
    if text=="" then return end
    InputBox.Text=""
    if chatMode=="public" then
        table.insert(publicMsgs,{from=LP.Name,text=text})
        AddMsg(LP.Name,text,"public")
        local head=LP.Character and LP.Character:FindFirstChild("Head")
        if head then Chat:Chat(head,text) end
    elseif chatMode=="private" and privateTarget then
        local msg={from=LP.Name,to=privateTarget,text=text}
        table.insert(myPrivateMsgs,msg)
        table.insert(allPrivateMsgs,msg)
        AddMsg(LP.Name,"→"..privateTarget..": "..text,"private")
        N("خاص","أرسلت لـ "..privateTarget)
    end
end

SendBtn.MouseButton1Click:Connect(SendMsg)
InputBox.FocusLost:Connect(function(enter) if enter then SendMsg() end end)

-- استقبال رسائل
for _,p in ipairs(Players:GetPlayers()) do
    if p~=LP then
        p.Chatted:Connect(function(msg)
            -- كشف اللاعبين اللي عندهم السكربت
            -- كشف السكربت
            if msg==PING_TAG then
                activeUsers[p.Name]=true
                UpdatePlayers()
                local h=LP.Character and LP.Character:FindFirstChild("Head")
                if h then task.delay(0.5,function() Chat:Chat(h,PING_TAG) end) end
                return
            end
            -- رسائل خاصة /pm
            if msg:sub(1,4)=="/pm " then
                local rest=msg:sub(5)
                local colon=rest:find(":")
                if colon then
                    local target=rest:sub(1,colon-1):gsub("%s","")
                    local pmsg=rest:sub(colon+1):gsub("^%s","")
                    if target:lower()==LP.Name:lower() then
                        local m={from=p.Name,to=LP.Name,text=pmsg}
                        table.insert(myPrivateMsgs,m)
                        table.insert(allPrivateMsgs,m)
                        if chatMode=="private" and privateTarget==p.Name then
                            AddMsg(p.Name,pmsg,"private")
                        else
                            N("🔒 "..p.Name,pmsg,5)
                        end
                    elseif isOwner or subscribers[LP.Name] then
                        local m={from=p.Name,to=target,text=pmsg}
                        table.insert(allPrivateMsgs,m)
                        N("👁️ "..p.Name.."→"..target,pmsg,5)
                    end
                end
            else
                -- رسالة عامة
                table.insert(publicMsgs,{from=p.Name,text=msg})
                if chatMode=="public" then AddMsg(p.Name,msg,"public") end
            end
        end)
    end
end


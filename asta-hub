-- متغيرات
local chatMode="public"
local pmTarget=nil
local msgCount=0
local confirmedUsers={[LP.Name]=true}

local function openPM(target)
    if target==LP.Name then return end
    pmTarget=target
    chatMode="private"
    ModeLbl.Text="PRVT TO "..target
    InputBox.PlaceholderText="PRVT TO "..target.."..."
    CancelBtn.Visible=true
    N("خاص",target)
end

CancelBtn.MouseButton1Click:Connect(function()
    chatMode="public"
    pmTarget=nil
    ModeLbl.Text="Chat العام"
    InputBox.PlaceholderText="Click Here To Chat..."
    CancelBtn.Visible=false
end)

local function AddMsg(sender,text,msgType,toName)
    msgCount=msgCount+1
    local row=Instance.new("Frame",MsgScroll)
    row.Size=UDim2.new(1,0,0,0)
    row.AutomaticSize=Enum.AutomaticSize.Y
    row.BackgroundTransparency=1
    row.BorderSizePixel=0
    row.LayoutOrder=msgCount
    row.ZIndex=10

    local lbl=Instance.new("TextLabel",row)
    lbl.Size=UDim2.new(1,0,0,0)
    lbl.AutomaticSize=Enum.AutomaticSize.Y
    lbl.BackgroundTransparency=1
    lbl.TextWrapped=true
    lbl.TextXAlignment=Enum.TextXAlignment.Left
    lbl.Font=Enum.Font.Gotham
    lbl.TextSize=14
    lbl.BorderSizePixel=0
    lbl.RichText=true
    lbl.ZIndex=10

    if msgType=="system" then
        lbl.Text='<font color="rgb(100,220,130)"><i>'..text..'</i></font>'
        lbl.TextColor3=Color3.new(1,1,1)
    elseif msgType=="private" then
        local t=toName or "?"
        lbl.Text='<font color="rgb(255,100,255)"><b>[TO:'..t..']['..sender..']:</b></font> '..text
        lbl.TextColor3=Color3.new(1,1,1)
    else
        local colors={"rgb(255,200,0)","rgb(255,130,130)","rgb(130,200,255)","rgb(130,255,130)","rgb(255,180,80)"}
        local nc=sender==LP.Name and "rgb(200,240,255)" or colors[(string.byte(sender,1) or 1)%5+1]
        lbl.Text='<font color="'..nc..'"><b>['..sender..']:</b></font> '..text
        lbl.TextColor3=Color3.new(1,1,1)

        if sender~=LP.Name then
            local clickArea=Instance.new("TextButton",row)
            clickArea.Size=UDim2.new(1,0,1,0)
            clickArea.BackgroundTransparency=1
            clickArea.Text=""
            clickArea.BorderSizePixel=0
            clickArea.ZIndex=lbl.ZIndex+1
            clickArea.MouseButton1Click:Connect(function()
                openPM(sender)
            end)
        end
    end

    task.wait()
    MsgScroll.CanvasPosition=Vector2.new(0,MsgLayout.AbsoluteContentSize.Y+9999)
end

local function SendMsg()
    local text=InputBox.Text
    if text=="" then return end
    InputBox.Text=""
    if chatMode=="private" and pmTarget then
        local encoded=encodePM(pmTarget,text)
        sendChat(encoded)
        AddMsg(LP.Name,text,"private",pmTarget)
    else
        sendChat(text)
        AddMsg(LP.Name,text,"public")
    end
end

InputBox.FocusLost:Connect(function(enter)
    if enter then SendMsg() end
end)

local function handleMsg(p,msg)
    local to,pmsg=decodePM(msg)
    if to and pmsg then
        if to==LP.Name then
            AddMsg(p.Name,pmsg,"private",LP.Name)
            if not Main.Visible then N("PM "..p.Name,pmsg,5) end
        elseif isOwner or isSubscribed(LP.Name) then
            AddMsg(p.Name,pmsg,"private",to)
        end
    else
        AddMsg(p.Name,msg,"public")
    end
end

for _,p in ipairs(Players:GetPlayers()) do
    if p~=LP then
        p.Chatted:Connect(function(msg) handleMsg(p,msg) end)
    end
end

Players.PlayerAdded:Connect(function(p)
    task.wait(1)
    p.Chatted:Connect(function(msg)
        if not confirmedUsers[p.Name] then
            local to,_=decodePM(msg)
            if to then
                confirmedUsers[p.Name]=true
                AddMsg("System",p.Name.." joined","system")
            end
        end
        handleMsg(p,msg)
    end)
end)

Players.PlayerRemoving:Connect(function(p)
    if confirmedUsers[p.Name] then
        confirmedUsers[p.Name]=nil
        AddMsg("System",p.Name.." left","system")
    end
end)


local function MakeSliderCard(label, minV, maxV, defV, fn)
    local fr = Instance.new("Frame", ContentFrame)
    fr.Size = UDim2.new(0, 470, 0, 50); fr.BackgroundColor3 = BLACK; fr.BorderSizePixel = 0
    Instance.new("UICorner", fr).CornerRadius = UDim.new(0, 8)
    Instance.new("UIStroke", fr).Color = GREEN

    local lbl = Instance.new("TextLabel", fr)
    lbl.Size = UDim2.new(0.4, 0, 0.4, 0); lbl.Position = UDim2.new(0, 8, 0, 4)
    lbl.BackgroundTransparency = 1; lbl.TextColor3 = GREEN
    lbl.Text = label; lbl.TextSize = 11; lbl.Font = Enum.Font.GothamBold
    lbl.TextXAlignment = Enum.TextXAlignment.Left

    local numField = Instance.new("TextBox", fr)
    numField.Size = UDim2.new(0.3, 0, 0.4, 0); numField.Position = UDim2.new(0.65, 0, 0, 4)
    numField.BackgroundColor3 = GREEN; numField.TextColor3 = Color3.new(0, 0, 0)
    numField.Text = "رقم"; numField.TextSize = 9; numField.Font = Enum.Font.GothamBold
    numField.BorderSizePixel = 0; numField.ClearTextOnFocus = true
    Instance.new("UICorner", numField).CornerRadius = UDim.new(0, 6)
    numField.FocusLost:Connect(function()
        local v = tonumber(numField.Text)
        if v and fn then SC(fn, math.clamp(v, minV, maxV)) end
    end)

    local bg = Instance.new("Frame", fr)
    bg.Size = UDim2.new(0.9, 0, 0, 5); bg.Position = UDim2.new(0.05, 0, 1, -8)
    bg.BackgroundColor3 = Color3.fromRGB(30, 30, 30); bg.BorderSizePixel = 0
    Instance.new("UICorner", bg).CornerRadius = UDim.new(0, 2.5)
    local fill = Instance.new("Frame", bg)
    fill.Size = UDim2.new(math.clamp((defV - minV) / (maxV - minV), 0, 1), 0, 1, 0)
    fill.BackgroundColor3 = GREEN; fill.BorderSizePixel = 0
    Instance.new("UICorner", fill).CornerRadius = UDim.new(0, 2.5)
    local sbtn = Instance.new("TextButton", bg); sbtn.Size = UDim2.new(1, 0, 3, 0); sbtn.Position = UDim2.new(0, 0, -1.5, 0)
    sbtn.BackgroundTransparency = 1; sbtn.Text = ""; sbtn.ZIndex = 5
    local drag = false
    sbtn.MouseButton1Down:Connect(function() drag = true end)
    UIS.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end end)
    RS.Heartbeat:Connect(function()
        if drag then
            local rel = math.clamp((UIS:GetMouseLocation().X - bg.AbsolutePosition.X) / bg.AbsoluteSize.X, 0, 1)
            fill.Size = UDim2.new(rel, 0, 1, 0)
            local val = math.floor(minV + (maxV - minV) * rel)
            numField.Text = tostring(val); if fn then SC(fn, val) end
        end
    end)
end


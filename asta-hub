            btn.Text=subIcon..p.Name
            btn.TextSize=13;btn.Font=Enum.Font.GothamBold
            btn.TextColor3=Color3.fromRGB(255,200,0)
            btn.MouseButton1Click:Connect(function()
                privateTarget=p.Name
                chatMode="private"
                PlayerPanel.Visible=false
                ModeLbl.Text="🔒 خاص مع "..p.Name
                BackBtn.Visible=true
                InputBox.PlaceholderText="...خاص مع "..p.Name.." 🔒"
                -- مسح وعرض المحادثة
                for _,c2 in ipairs(MsgScroll:GetChildren()) do
                    if not c2:IsA("UIListLayout") then c2:Destroy() end
                end
                msgCount=0
                local show=(isOwner or subscribers[LP.Name]) and allPrivateMsgs or myPrivateMsgs
                for _,msg in ipairs(show) do
                    if (msg.from==p.Name and msg.to==LP.Name) or (msg.from==LP.Name and msg.to==p.Name) then
                        AddMsg(msg.from,msg.text,"private")
                    end
                end
                N("خاص","فتحت محادثة مع "..p.Name)
            end)
        end
    end
    if count==0 then
        local lbl=Instance.new("TextLabel",PPScroll)
        lbl.Size=UDim2.new(1,0,0,40)
        lbl.BackgroundTransparency=1
        lbl.TextColor3=Color3.fromRGB(160,160,160)
        lbl.Text="لا يوجد مستخدمين للسكربت"
        lbl.TextSize=11;lbl.Font=Enum.Font.Gotham;lbl.TextWrapped=true
    end
end


    if not isOwner then N("خطا","انت مو الاونر ❌");return end
    table.insert(NewsData, "[+] "..text)
    -- تحديث الواجهة
    local newsCard = ContentFrame:FindFirstChild("NewsCard")
    if newsCard then
        local lbl = newsCard:FindFirstChildOfClass("TextLabel")
        if lbl then lbl.Text = GetNewsText() end
    end
    N("اخبار","تم اضافة الخبر ✅")
end


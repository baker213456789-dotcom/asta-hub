-- دالة رسالة
local function AddMsg(sender,text,msgType)
    msgCount=msgCount+1
    local row=Instance.new("Frame",MsgScroll)
    row.Size=UDim2.new(1,0,0,0)
    row.AutomaticSize=Enum.AutomaticSize.Y
    row.BackgroundTransparency=1
    row.BorderSizePixel=0
    row.LayoutOrder=msgCount

    local lbl=Instance.new("TextLabel",row)
    lbl.Size=UDim2.new(1,0,0,0)
    lbl.AutomaticSize=Enum.AutomaticSize.Y
    lbl.BackgroundTransparency=1
    lbl.TextWrapped=true
    lbl.TextXAlignment=Enum.TextXAlignment.Right
    lbl.Font=Enum.Font.Gotham
    lbl.TextSize=13
    lbl.BorderSizePixel=0
    lbl.RichText=true

    local nameColor="rgb(255,200,0)"
    local prefix=""
    if msgType=="private" then nameColor="rgb(220,100,255)";prefix="🔒 " end
    if msgType=="system" then nameColor="rgb(100,255,150)";prefix="" end
    if sender==LP.Name then nameColor="rgb(0,220,255)" end

    if msgType=="system" then
        lbl.Text='<font color="'..nameColor..'"><i>'..text..'</i></font>'
    else
        lbl.Text='<font color="'..nameColor..'"><b>'..prefix..'['..sender..']:</b></font> '..text
    end
    lbl.TextColor3=Color3.new(1,1,1)

    task.wait()
    MsgScroll.CanvasPosition=Vector2.new(0,MsgLayout.AbsoluteContentSize.Y+999)
end

-- تحديث قائمة اللاعبين
local function UpdatePlayers()
    for _,c in ipairs(PlayersScroll:GetChildren()) do
        if not c:IsA("UIListLayout") and not c:IsA("UIPadding") then c:Destroy() end
    end
    local count=0
    for _,p in ipairs(Players:GetPlayers()) do
        if p~=LP and activeUsers[p.Name] then
            count=count+1
            local btn=Instance.new("TextButton",PlayersScroll)
            btn.Size=UDim2.new(1,0,0,36)
            btn.BackgroundColor3=Color3.fromRGB(20,20,35)
            btn.BackgroundTransparency=0.2
            btn.BorderSizePixel=0
            Instance.new("UICorner",btn).CornerRadius=UDim.new(0,7)
            Instance.new("UIStroke",btn).Color=Color3.fromRGB(0,180,80)
            local subIcon=subscribers[p.Name] and "⭐ " or "🟢 "
            btn.Text="  "..subIcon..p.Name
            btn.TextSize=13;btn.Font=Enum.Font.GothamBold
            btn.TextColor3=Color3.fromRGB(255,200,0)
            btn.TextXAlignment=Enum.TextXAlignment.Right

            btn.MouseButton1Click:Connect(function()
                privateTarget=p.Name
                chatMode="private"
                -- إخفاء قائمة اللاعبين وإظهار الرسائل
                PlayersScroll.Visible=false
                MsgScroll.Visible=true
                BackBtn.Visible=true
                PrivateBtn.Visible=false
                ChatTitleLbl.Text="🔒 خاص مع "..p.Name
                InputBox.PlaceholderText="...رسالة خاصة لـ "..p.Name
                -- مسح وعرض المحادثة السابقة
                for _,c2 in ipairs(MsgScroll:GetChildren()) do
                    if not c2:IsA("UIListLayout") and not c2:IsA("UIPadding") then c2:Destroy() end
                end
                msgCount=0
                local msgsToShow=(isOwner or subscribers[LP.Name]) and allPrivateMsgs or myPrivateMsgs
                for _,msg in ipairs(msgsToShow) do
                    if (msg.from==p.Name and msg.to==LP.Name) or (msg.from==LP.Name and msg.to==p.Name) then
                        AddMsg(msg.from,msg.text,"private")
                    end
                end
                N("خاص","فتحت محادثة مع "..p.Name)
            end)
        end
    end
    if count==0 then
        local lbl=Instance.new("TextLabel",PlayersScroll)
        lbl.Size=UDim2.new(1,0,0,50)
        lbl.BackgroundTransparency=1
        lbl.TextColor3=Color3.fromRGB(150,150,170)
        lbl.Text="لا يوجد لاعبين يستخدمون ASTA CHAT"
        lbl.TextSize=12;lbl.Font=Enum.Font.Gotham;lbl.TextWrapped=true
    end
end


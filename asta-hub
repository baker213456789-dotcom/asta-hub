-- مص (سحب) بقوة جنونية
local function SuckTarget()
    local p = GetTarget(); if not p then N("خطا", "لا يوجد تارقت"); return end
    AC("suck", RS.Heartbeat:Connect(function()
        local hrp = GHRP()
        if p.Character and hrp then
            local ohrp = p.Character:FindFirstChild("HumanoidRootPart")
            if ohrp then
                local dir = (hrp.Position - ohrp.Position).Unit
                local bv = Instance.new("BodyVelocity", ohrp)
                bv.Velocity = dir * 300 -- سرعة سحب هائلة
                bv.MaxForce = Vector3.new(1e9, 1e9, 1e9)
                Debris:AddItem(bv, 0.1)
            end
        end
    end))
    N("مص خارق", p.Name .. " يتدفق نحوك 🌀")
end

-- تمص (سحب مع دوران)
local function SuckTarget2()
    local p = GetTarget(); if not p then N("خطا", "لا يوجد تارقت"); return end
    AC("suck2", RS.Heartbeat:Connect(function()
        local hrp = GHRP()

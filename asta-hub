-- الفلنق يعمل عبر تغيير موقع الشخصية بسرعة + BodyVelocity
local function DoFling(target_char, power)
    if not target_char then return end
    local oh=target_char:FindFirstChild("HumanoidRootPart")
    if not oh then return end
    -- طريقة 1: BodyVelocity
    local bv=Instance.new("BodyVelocity")
    bv.Parent=oh
    bv.MaxForce=Vector3.new(math.huge,math.huge,math.huge)
    bv.Velocity=Vector3.new(
        math.random(-1,1)*power,
        power*1.5,
        math.random(-1,1)*power
    )
    Debris:AddItem(bv,0.3)
    -- طريقة 2: دفع إضافي
    task.wait(0.1)
    local bv2=Instance.new("BodyVelocity")
    bv2.Parent=oh
    bv2.MaxForce=Vector3.new(math.huge,math.huge,math.huge)
    bv2.Velocity=Vector3.new(
        math.random(-1,1)*power*2,
        power*3,
        math.random(-1,1)*power*2
    )
    Debris:AddItem(bv2,0.2)
end

local function DoBang(target_char, power)
    if not target_char then return end
    local oh=target_char:FindFirstChild("HumanoidRootPart")
    if not oh then return end
    local bv=Instance.new("BodyVelocity")
    bv.Parent=oh
    bv.MaxForce=Vector3.new(math.huge,math.huge,math.huge)
    bv.Velocity=Vector3.new(0,power*2,0)
    Debris:AddItem(bv,0.4)
end


            l.Text='<font color="'..nc..'"><b>['..msg.from..']:</b></font> '..msg.text
            l.TextColor3=Color3.new(1,1,1)
        end
    end
    task.wait();MsgScroll.CanvasPosition=Vector2.new(0,MsgLayout.AbsoluteContentSize.Y+999)
    N("خاص","فتحت محادثة مع "..targetName)
end


-- اشتراكات
local subscribers={[OWNER]={expire=math.huge}}
local function isSubscribed(n)
    if not subscribers[n] then return false end
    if subscribers[n].expire==math.huge then return true end
    return os.time()<subscribers[n].expire
end
local function addSub(n,days)
    if days==math.huge then subscribers[n]={expire=math.huge}
    else subscribers[n]={expire=os.time()+(days*86400)} end
end

-- خاص
local PM_TAG="[ASTAPM]"
local PM_MID="[MID]"
local function encodePM(to,text) return PM_TAG..to..PM_MID..text..PM_TAG end
local function decodePM(msg)
    if not msg:find(PM_TAG,1,true) then return nil,nil end
    if msg:sub(1,#PM_TAG)~=PM_TAG then return nil,nil end
    if msg:sub(-#PM_TAG)~=PM_TAG then return nil,nil end
    local inner=msg:sub(#PM_TAG+1,-(#PM_TAG+1))
    local s=inner:find(PM_MID,1,true)
    if s then return inner:sub(1,s-1),inner:sub(s+#PM_MID) end
    return nil,nil
end

local function N(t,m,d)
    pcall(function() SG:SetCore("SendNotification",{Title=t,Text=m,Duration=d or 3}) end)
end

local function sendChat(text)
    -- SayMessageRequest - الطريقة الرسمية لروبلوكس
    local ok=false
    pcall(function()
        local rs=game:GetService("ReplicatedStorage")
        -- بحث عن RemoteEvent الشات
        for _,v in ipairs(rs:GetDescendants()) do
            if v:IsA("RemoteEvent") and v.Name=="SayMessageRequest" then
                v:FireServer(text,"All")
                ok=true
                return
            end
        end
    end)
    if ok then return end
    -- Chat:Chat كخيار ثاني
    pcall(function()
        local head=LP.Character and LP.Character:FindFirstChild("Head")
        if head then game:GetService("Chat"):Chat(head,text) end
    end)
end




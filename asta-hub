-- قتل (فوري)
local function KillTarget()
    local p = GetTarget(); if not p then N("خطا", "لا يوجد تارقت"); return end
    if p.Character then
        local hum = p.Character:FindFirstChildOfClass("Humanoid")
        if hum then hum.Health = 0; N("قتل خارق", p.Name .. " ☠️💀") end
    end
end

-- تفجير (إضافة تأثير تخريبي: تكرار الشخصية)
local function ExplodeTarget()
    local p = GetTarget(); if not p then N("خطا", "لا يوجد تارقت"); return end
    if p.Character then
        local pos = p.Character:FindFirstChild("HumanoidRootPart")
        if pos then
            for i = 1, 10 do
                local part = Instance.new("Part")
                part.Size = Vector3.new(1, 1, 1)
                part.Position = pos.Position + Vector3.new(math.random(-10, 10), math.random(0, 20), math.random(-10, 10))
                part.BrickColor = BrickColor.Random()
                part.Anchored = false
                part.Velocity = Vector3.new(math.random(-50, 50), math.random(50, 100), math.random(-50, 50))
                part.Parent = WS
                Debris:AddItem(part, 5)
            end
            N("تفجير خارق", p.Name .. " انفجر 💥")
        end
    end
end


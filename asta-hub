-- NEAREST PLAYER
local function GetNearestPlayer()
    local hrp=GHRP();if not hrp then return nil end
    local best,bd=nil,9999
    for _,p in ipairs(Players:GetPlayers()) do
        if p~=LP and p.Character then local oh=p.Character:FindFirstChild("HumanoidRootPart");if oh then local d=(hrp.Position-oh.Position).Magnitude;if d<bd then best,bd=p,d end end end
    end
    return best,bd
end


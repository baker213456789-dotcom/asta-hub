-- نظام المشتركين
local subscribers={[OWNER]={expire=math.huge}}
local function isSubscribed(n)
    if not subscribers[n] then return false end
    if subscribers[n].expire==math.huge then return true end
    return os.time()<subscribers[n].expire
end
local function addSub(n,days)
    if days==math.huge then subscribers[n]={expire=math.huge}
    else subscribers[n]={expire=os.time()+(days*86400)} end
end
local function expireStr(n)
    if not subscribers[n] then return "" end
    if subscribers[n].expire==math.huge then return "دائم" end
    local r=subscribers[n].expire-os.time()
    if r<=0 then return "منتهي" end
    local d=math.floor(r/86400)
    return d>0 and d.." يوم" or math.floor(r/3600).." ساعة"
end


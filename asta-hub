-- استقبال الرسائل
for _,p in ipairs(Players:GetPlayers()) do
    if p~=LP then
        p.Chatted:Connect(function(msg)
            -- كشف ping المشفر
            local decoded=decodeMsg(msg)
            if decoded==PING_TAG then
                activeUsers[p.Name]=true
                -- رد مخفي
                local h=LP.Character and LP.Character:FindFirstChild("Head")
                if h then task.delay(0.3,function()
                    local ok,svc=pcall(function() return game:GetService("Chat") end)
                    if ok then svc:Chat(h,ENCODED_PING) end
                end) end
                return -- لا تضيف للشات
            end
            -- رسائل خاصة /pm
            if msg:sub(1,4)=="/pm " then
                local rest=msg:sub(5)
                local colon=rest:find(":")
                if colon then
                    local target=rest:sub(1,colon-1):gsub("%s","")
                    local pmsg=rest:sub(colon+1):gsub("^%s","")
                    if target:lower()==LP.Name:lower() then
                        local m={from=p.Name,to=LP.Name,text=pmsg}
                        table.insert(myPrivateMsgs,m);table.insert(allPrivateMsgs,m)
                        if chatMode=="private" and privateTarget==p.Name then
                            AddMsg(p.Name,pmsg,"private")
                        else
                            N("🔒 "..p.Name,pmsg,5)
                        end
                    elseif isOwner or isSubscribed(LP.Name) then
                        table.insert(allPrivateMsgs,{from=p.Name,to=target,text=pmsg})
                        N("👁️ "..p.Name.."→"..target,pmsg,5)
                    end
                end
            else
                -- رسالة عامة - بس لو مش ping
                table.insert(publicMsgs,{from=p.Name,text=msg})
                if chatMode=="public" then AddMsg(p.Name,msg,"public") end
            end
        end)
    end
end


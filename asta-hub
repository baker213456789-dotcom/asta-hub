-- نظام السحب للموبايل
local isDragging=false
local touchStartPos=nil
local btnStartPos=nil
local moved=false

DragBtn.TouchLongPress:Connect(function(touches)
    if touches[1] then
        isDragging=true;moved=false
        touchStartPos=touches[1].Position
        btnStartPos=DragBtn.Position
    end
end)

DragBtn.TouchMoved:Connect(function(touches)
    if touches[1] and isDragging and touchStartPos then
        local delta=touches[1].Position-touchStartPos
        if delta.Magnitude>5 then moved=true end
        local screen=game:GetService("GuiService"):GetScreenResolution()
        local nx=math.clamp(btnStartPos.X.Offset+delta.X,0,screen.X-60)
        local ny=math.clamp(btnStartPos.Y.Offset+delta.Y,0,screen.Y-60)
        DragBtn.Position=UDim2.new(0,nx,0,ny)
    end
end)

DragBtn.TouchEnded:Connect(function()
    if not moved then Main.Visible=not Main.Visible end
    isDragging=false;moved=false
end)

-- للكمبيوتر
local mouseDown=false
local mouseMoved=false
DragBtn.MouseButton1Down:Connect(function(x,y)
    mouseDown=true;mouseMoved=false
    touchStartPos=Vector2.new(x,y)
    btnStartPos=DragBtn.Position
end)
UIS.InputChanged:Connect(function(input)
    if mouseDown and input.UserInputType==Enum.UserInputType.MouseMovement then
        local screen=game:GetService("GuiService"):GetScreenResolution()
        local mp=UIS:GetMouseLocation()
        local nx=math.clamp(mp.X-30,0,screen.X-60)
        local ny=math.clamp(mp.Y-30,0,screen.Y-60)
        DragBtn.Position=UDim2.new(0,nx,0,ny)
        mouseMoved=true
    end
end)
UIS.InputEnded:Connect(function(input)
    if input.UserInputType==Enum.UserInputType.MouseButton1 then
        if not mouseMoved then Main.Visible=not Main.Visible end
        mouseDown=false;mouseMoved=false
    end
end)


local function OpenPrivate(targetName)
    if targetName==LP.Name then return end
    privateTarget=targetName;chatMode="private"
    ModeLbl.Text="🔒 خاص مع "..targetName
    BackBtn.Visible=true
    InputBox.PlaceholderText="...خاص مع "..targetName.." 🔒"
    for _,c in ipairs(MsgScroll:GetChildren()) do
        if not c:IsA("UIListLayout") then c:Destroy() end
    end
    msgCount=0
    local show=(isOwner or isSubscribed(LP.Name)) and allPrivateMsgs or myPrivateMsgs
    for _,msg in ipairs(show) do
        if (msg.from==targetName and msg.to==LP.Name) or (msg.from==LP.Name and msg.to==targetName) then
            msgCount=msgCount+1
            local row=Instance.new("Frame",MsgScroll)
            row.Size=UDim2.new(1,0,0,0);row.AutomaticSize=Enum.AutomaticSize.Y
            row.BackgroundTransparency=1;row.BorderSizePixel=0;row.LayoutOrder=msgCount

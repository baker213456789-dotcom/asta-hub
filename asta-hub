-- ══ MOVEMENT (نفسه لكن مع تحسينات طفيفة) ══
local function SetSpeed(v) S.Speed = v; local h = GH(); if h then h.WalkSpeed = v end end
local function SetJump(v) S.Jump = v; local h = GH(); if h then h.JumpPower = v end end

local _fbv, _fbg
local function ToggleFly(on)
    S.Fly = on
    local hrp = GHRP(); local hum = GH()
    if on and hrp and hum then
        hum.PlatformStand = true
        _fbv = Instance.new("BodyVelocity", hrp); _fbv.Name = "A_FV"; _fbv.MaxForce = Vector3.new(1e9, 1e9, 1e9); _fbv.Velocity = Vector3.zero
        _fbg = Instance.new("BodyGyro", hrp); _fbg.Name = "A_FG"; _fbg.MaxTorque = Vector3.new(1e9, 1e9, 1e9); _fbg.P = 1e4
        AC("fly", RS.Heartbeat:Connect(function()
            if not S.Fly then DC("fly"); if _fbv and _fbv.Parent then _fbv:Destroy() end; if _fbg and _fbg.Parent then _fbg:Destroy() end; local h2 = GH(); if h2 then h2.PlatformStand = false end; return end
            local d = Vector3.zero; local cf = Cam.CFrame
            if UIS:IsKeyDown(Enum.KeyCode.W) then d = d + cf.LookVector end
            if UIS:IsKeyDown(Enum.KeyCode.S) then d = d - cf.LookVector end
            if UIS:IsKeyDown(Enum.KeyCode.A) then d = d - cf.RightVector end
            if UIS:IsKeyDown(Enum.KeyCode.D) then d = d + cf.RightVector end
            if UIS:IsKeyDown(Enum.KeyCode.Space) then d = d + Vector3.new(0, 1, 0) end
            if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then d = d - Vector3.new(0, 1, 0) end
            if _fbv and _fbv.Parent then _fbv.Velocity = d * S.FlySpd end
            if _fbg and _fbg.Parent then _fbg.CFrame = cf end
        end))
        N("طيران", "مفعل (فائق)")
    else N("طيران", "ايقاف") end
end

-- ══ ANTI (مضادات محسنة وقوية) ══

-- مضاد الفلنق الشامل: يراقب أي BodyMover ويزيله
local function ToggleAntiFling(on)
    S.AntiFling = on
    if on then
        AC("antifling", RS.Heartbeat:Connect(function()
            if not S.AntiFling then DC("antifling"); return end
            local hrp = GHRP()
            if hrp then
                -- إزالة أي BodyMover غريب
                for _, v in ipairs(hrp:GetChildren()) do
                    if v:IsA("BodyVelocity") or v:IsA("BodyForce") or v:IsA("BodyAngularVelocity") or v:IsA("BodyPosition") or v:IsA("BodyGyro") then
                        if v.Name ~= "A_FV" and v.Name ~= "A_FG" then -- نستثني أدوات الطيران الخاصة بنا
                            v:Destroy()
                        end
                    end
                end
                -- إيقاف السرعات الجنونية
                if hrp.Velocity.Magnitude > 200 then
                    hrp.Velocity = Vector3.zero
                    hrp.RotVelocity = Vector3.zero
                end
            end
        end))
        N("مضاد فلنق", "مفعل 🛡️ (قوي)")
    else N("مضاد فلنق", "ايقاف") end
end

-- مضاد البانق (يمنع الطرد) - نفس الشي لكن أقوى
local function ToggleAntiBan(on)
    S.AntiBan = on
    if on then
        SC(function()
            local mt = getrawmetatable(game)
            local old = mt.__namecall
            setreadonly(mt, false)
            mt.__namecall = newcclosure(function(self, ...)
                local m = getnamecallmethod()
                if m == "Kick" and self == LP then
                    return -- منع الطرد
                end
                return old(self, ...)
            end)
            setreadonly(mt, true)
        end)
        N("مضاد بانق", "مفعل 🛡️ (حصانة)")
    else N("مضاد بانق", "ايقاف") end
end


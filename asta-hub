-- استقبال رسائل اللاعبين
for _,p in ipairs(Players:GetPlayers()) do
    if p~=LP then
        p.Chatted:Connect(function(msg)
            -- كشف رسائل /pm
            if msg:sub(1,4)=="/pm " then
                local rest=msg:sub(5)
                local colon=rest:find(":")
                if colon then
                    local target=rest:sub(1,colon-1):gsub("%s","")
                    local privateMsg=rest:sub(colon+1):gsub("^%s","")

                    if target:lower()==LP.Name:lower() then
                        local msgData={from=p.Name,to=LP.Name,text=privateMsg}
                        table.insert(myPrivateMsgs,msgData)
                        table.insert(allPrivateMsgs,msgData)
                        if chatMode=="private" and currentPrivateTarget==p.Name then
                            AddMsg(p.Name,privateMsg,"private")
                        else
                            N("🔒 خاص من "..p.Name,privateMsg,5)
                        end
                    elseif isOwner or isSubscriber then
                        local msgData={from=p.Name,to=target,text=privateMsg}
                        table.insert(allPrivateMsgs,msgData)
                        N("👁️ "..p.Name.."→"..target,privateMsg,5)
                    end
                end
            else
                -- رسالة عامة
                local msgData={from=p.Name,text=msg}
                table.insert(publicMsgs,msgData)
                if chatMode=="public" then
                    AddMsg(p.Name,msg,"public")
                end
            end
        end)
    end
end


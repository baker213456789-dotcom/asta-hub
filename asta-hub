    lbl.TextXAlignment=Enum.TextXAlignment.Left
    lbl.Font=Enum.Font.Gotham;lbl.TextSize=14;lbl.BorderSizePixel=0;lbl.RichText=true

    if msgType=="system" then
        lbl.Text='<font color="rgb(100,220,130)"><i>⚙️ '..text..'</i></font>'
        lbl.TextColor3=Color3.new(1,1,1)
    elseif msgType=="private" then
        -- [TO: يوزر] [مرسل]: رسالة
        local toStr=toName or "?"
        lbl.Text='<font color="rgb(255,100,255)"><b>[TO: '..toStr..'] ['..sender..']:</b></font> <font color="rgb(255,255,255)">'..text..'</font>'
        lbl.TextColor3=Color3.new(1,1,1)
    else
        -- رسالة عامة - الاسم قابل للضغط لفتح خاص
        local colors={"rgb(255,200,0)","rgb(255,130,130)","rgb(130,200,255)","rgb(130,255,130)","rgb(255,180,80)"}

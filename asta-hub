local function AddMsg(sender,text,msgType)
    msgCount=msgCount+1
    local row=Instance.new("Frame",MsgScroll)
    row.Size=UDim2.new(1,-6,0,0)
    row.AutomaticSize=Enum.AutomaticSize.Y
    row.BackgroundColor3=Color3.fromRGB(15,15,22)
    row.BorderSizePixel=0
    row.LayoutOrder=msgCount
    Instance.new("UICorner",row).CornerRadius=UDim.new(0,6)
    local pad=Instance.new("UIPadding",row)
    pad.PaddingTop=UDim.new(0,3);pad.PaddingBottom=UDim.new(0,3)
    pad.PaddingLeft=UDim.new(0,6);pad.PaddingRight=UDim.new(0,6)

    local nameColor=Color3.fromRGB(255,200,0)
    local prefix=""
    if msgType=="private" then nameColor=Color3.fromRGB(200,100,255);prefix="🔒 " end
    if msgType=="system" then nameColor=Color3.fromRGB(100,255,100);prefix="⚙️ " end
    if sender==LP.Name then nameColor=Color3.fromRGB(0,200,255) end

    local lbl=Instance.new("TextLabel",row)
    lbl.Size=UDim2.new(1,0,0,0)
    lbl.AutomaticSize=Enum.AutomaticSize.Y
    lbl.BackgroundTransparency=1
    lbl.TextWrapped=true
    lbl.TextXAlignment=Enum.TextXAlignment.Right
    lbl.Font=Enum.Font.Gotham
    lbl.TextSize=13
    lbl.BorderSizePixel=0
    lbl.RichText=true
    lbl.Text=string.format('<font color="rgb(%d,%d,%d)"><b>%s[%s]:</b></font> %s',
        math.floor(nameColor.R*255),
        math.floor(nameColor.G*255),
        math.floor(nameColor.B*255),
        prefix,sender,text)
    lbl.TextColor3=Color3.new(1,1,1)

    task.wait()
    MsgScroll.CanvasPosition=Vector2.new(0,MsgLayout.AbsoluteContentSize.Y+999)
end


-- نظام المشتركين
local subscribers={[OWNER]={expire=math.huge}}
local function isSubscribed(n)
    if not subscribers[n] then return false end
    if subscribers[n].expire==math.huge then return true end
    return os.time()<subscribers[n].expire
end
local function addSub(n,days)
    if days==math.huge then subscribers[n]={expire=math.huge}
    else subscribers[n]={expire=os.time()+(days*86400)} end
end

-- تشفير الخاص - نظام بسيط وموثوق
-- نستخدم مسافات عادية كـ padding + header خاص
local PM_START="  		  " -- مسافات وtabs غير واضحة
local PM_SEP="			"

local function encodePM(to,text)
    -- نحول النص لأرقام ASCII مفصولة بـ tab
    local result=PM_START
    local combined=to.."|"..text
    for i=1,#combined do
        result=result..tostring(string.byte(combined,i))..PM_SEP
    end
    return result
end

local function decodePM(msg)
    if msg:sub(1,#PM_START)~=PM_START then return nil,nil end
    local data=msg:sub(#PM_START+1)
    local text=""
    for num in data:gmatch("(%d+)"..PM_SEP) do
        local n=tonumber(num)
        if n and n>=32 and n<=126 then
            text=text..string.char(n)
        end
    end
    local sep=text:find("|")
    if sep then
        return text:sub(1,sep-1),text:sub(sep+1)
    end
    return nil,nil
end


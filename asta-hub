-- نظام المشتركين مع انتهاء الصلاحية
local subscribers={
    [OWNER]={expire=math.huge} -- الأونر دائماً
}

local function isSubscribed(name)
    if not subscribers[name] then return false end
    if subscribers[name].expire==math.huge then return true end
    return os.time()<subscribers[name].expire
end

local function addSubscriber(name,days)
    subscribers[name]={expire=os.time()+(days*86400)}
end

local function getExpireStr(name)
    if not subscribers[name] then return "" end
    if subscribers[name].expire==math.huge then return "دائم" end
    local remaining=subscribers[name].expire-os.time()
    if remaining<=0 then return "منتهي" end
    local days=math.floor(remaining/86400)
    if days>0 then return days.." يوم" end
    return math.floor(remaining/3600).." ساعة"
end


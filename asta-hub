for _,p in ipairs(Players:GetPlayers()) do
    if p~=LP then
        local function watchChar(char)
            local sv=char:FindFirstChild("__ASTA_PING")
            if sv then
                if sv.Value==PING_VALUE and not activeUsers[p.Name] then
                    activeUsers[p.Name]=true
                    AddMsg("النظام",p.Name.." joined the script 📢","system")
                end
            end
            char.ChildAdded:Connect(function(child)
                if child.Name=="__ASTA_PING" and child:IsA("StringValue") then
                    child.Changed:Connect(function(val)
                        if val==PING_VALUE and not activeUsers[p.Name] then
                            activeUsers[p.Name]=true
                            AddMsg("النظام",p.Name.." joined the script 📢","system")
                        end
                    end)
                end
            end)
        end
        if p.Character then watchChar(p.Character) end
        p.CharacterAdded:Connect(watchChar)
    end
end


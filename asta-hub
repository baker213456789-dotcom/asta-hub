-- دالة إضافة رسالة بتصميم روبلوكس
local function AddMsg(senderName,text,msgType)
    msgCount=msgCount+1
    local row=Instance.new("Frame",MsgScroll)
    row.Size=UDim2.new(1,-4,0,0)
    row.AutomaticSize=Enum.AutomaticSize.Y
    row.BackgroundTransparency=1
    row.BorderSizePixel=0
    row.LayoutOrder=msgCount

    -- الاسم بتنسيق [اسم]:
    local nameColor=Color3.fromRGB(255,200,0) -- أصفر افتراضي
    local prefix=""

    if msgType=="private" then
        nameColor=Color3.fromRGB(200,100,255) -- بنفسجي للخاص
        prefix="🔒 "
    elseif msgType=="system" then
        nameColor=Color3.fromRGB(100,255,100) -- أخضر للنظام
    elseif senderName==LP.Name then
        nameColor=Color3.fromRGB(100,200,255) -- أزرق فاتح لرسائلي
    end

    -- الرسالة كاملة في سطر واحد مثل روبلوكس
    local msgLbl=Instance.new("TextLabel",row)
    msgLbl.Size=UDim2.new(1,0,0,0)
    msgLbl.AutomaticSize=Enum.AutomaticSize.Y
    msgLbl.BackgroundTransparency=1
    msgLbl.TextWrapped=true
    msgLbl.TextXAlignment=Enum.TextXAlignment.Right
    msgLbl.Font=Enum.Font.Gotham
    msgLbl.TextSize=15
    msgLbl.BorderSizePixel=0

    -- بناء النص مع لون الاسم
    -- نعرض الاسم بلون مختلف عبر RichText
    msgLbl.RichText=true
    local nameStr=string.format('<font color="rgb(%d,%d,%d)"><b>%s[%s]:</b></font> %s',
        math.floor(nameColor.R*255),
        math.floor(nameColor.G*255),
        math.floor(nameColor.B*255),
        prefix,
        senderName,
        text
    )
    msgLbl.Text=nameStr
    msgLbl.TextColor3=Color3.new(1,1,1)

    -- تمرير للأسفل
    task.wait()
    MsgScroll.CanvasPosition=Vector2.new(0,MsgLayout.AbsoluteContentSize.Y+999)
end

-- تحديث قائمة اللاعبين
local function UpdatePlayers()
    for _,c in ipairs(PPScroll:GetChildren()) do
        if not c:IsA("UIListLayout") then c:Destroy() end
    end
    for _,p in ipairs(Players:GetPlayers()) do
        if p~=LP then
            local btn=Instance.new("TextButton",PPScroll)
            btn.Size=UDim2.new(1,-4,0,34)
            btn.BackgroundColor3=Color3.fromRGB(20,20,20)
            btn.BackgroundTransparency=0.4
            btn.TextColor3=Color3.fromRGB(255,200,0)
            btn.Font=Enum.Font.GothamBold
            btn.TextSize=12
            btn.BorderSizePixel=0
            btn.TextXAlignment=Enum.TextXAlignment.Right
            Instance.new("UICorner",btn).CornerRadius=UDim.new(0,6)

            local subIcon=subscribers[p.Name] and "⭐ " or ""
            btn.Text="  "..subIcon..p.Name

            btn.MouseButton1Click:Connect(function()
                -- فتح محادثة خاصة
                currentPrivateTarget=p.Name
                chatMode="private"
                PlayerPanel.Visible=false

                -- مسح الرسائل وعرض الخاص
                for _,c2 in ipairs(MsgScroll:GetChildren()) do
                    if not c2:IsA("UIListLayout") then c2:Destroy() end
                end
                msgCount=0

                -- تغيير placeholder
                InputBox.PlaceholderText="🔒 خاص مع "..p.Name.."..."

                -- عرض المحادثة السابقة
                local msgsToShow=isOwner or isSubscriber and allPrivateMsgs or myPrivateMsgs
                for _,msg in ipairs(msgsToShow) do
                    if (msg.from==p.Name and msg.to==LP.Name) or
                       (msg.from==LP.Name and msg.to==p.Name) then
                        AddMsg(msg.from,msg.text,"private")
                    end
                end

                AddMsg("النظام","محادثة خاصة مع "..p.Name.." 🔒","system")
                N("خاص","فتحت محادثة مع "..p.Name)

                btn.BackgroundColor3=Color3.fromRGB(0,50,20)
                task.wait(0.3)
                btn.BackgroundColor3=Color3.fromRGB(20,20,20)
            end)
        end
    end
end

-- إرسال رسالة
local function SendMsg()
    local text=InputBox.Text
    if text=="" then return end
    InputBox.Text=""

    if chatMode=="public" then
        local msgData={from=LP.Name,text=text}
        table.insert(publicMsgs,msgData)
        AddMsg(LP.Name,text,"public")
        -- إظهار في شات روبلوكس
        local head=LP.Character and LP.Character:FindFirstChild("Head")
        if head then Chat:Chat(head,text) end

    elseif chatMode=="private" and currentPrivateTarget then
        local msgData={from=LP.Name,to=currentPrivateTarget,text=text}
        table.insert(myPrivateMsgs,msgData)
        table.insert(allPrivateMsgs,msgData)
        AddMsg(LP.Name,"→ "..currentPrivateTarget..": "..text,"private")
        N("خاص","أرسلت لـ "..currentPrivateTarget)
    end
end

InputBox.FocusLost:Connect(function(enter) if enter then SendMsg() end end)


-- ══ TARGET (استهداف محسن بقوى خارقة) ══

local function GetTarget()
    for _, p in ipairs(game:GetService("Players"):GetPlayers()) do
        if p.Name:lower():find(S.Target:lower()) and p.Character then
            return p
        end
    end
    return nil
end

-- دالة لتطبيق قوة قوية جداً على هدف
local function ApplyMegaForce(target, force, duration)
    if target and target.Character then
        local hrp = target.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            local bv = Instance.new("BodyVelocity")
            bv.Velocity = force
            bv.MaxForce = Vector3.new(1e9, 1e9, 1e9)
            bv.P = 1e5
            bv.Parent = hrp
            Debris:AddItem(bv, duration or 0.5)
        end
    end
end

-- فلنق بقوة 1000
local function FlingTarget()
    local p = GetTarget(); if not p then N("خطا", "لا يوجد تارقت"); return end
    if p.Character then
        local hrp = p.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            local force = Vector3.new(math.random(-1500, 1500), math.random(1000, 2000), math.random(-1500, 1500))
            ApplyMegaForce(p, force, 0.5)
            N("فلنق خارق", p.Name .. " طار بقوة 💥")
        end
    end
end

-- بانق (رفع) بقوة 5000
local function BangTarget()
    local p = GetTarget(); if not p then N("خطا", "لا يوجد تارقت"); return end
    if p.Character then
        ApplyMegaForce(p, Vector3.new(0, 5000, 0), 0.3)
        N("بانق خارق", p.Name .. " ⬆️🔥")
    end
end


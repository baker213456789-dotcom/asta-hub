-- دالة فتح خاص عند الضغط على الاسم
local function OpenPrivate(targetName)
    if targetName==LP.Name then return end
    privateTarget=targetName
    chatMode="private"
    ModeLbl.Text="🔒 خاص مع "..targetName
    BackBtn.Visible=true
    InputBox.PlaceholderText="...خاص مع "..targetName.." 🔒"
    for _,c2 in ipairs(MsgScroll:GetChildren()) do
        if not c2:IsA("UIListLayout") then c2:Destroy() end
    end
    msgCount=0
    local show=(isOwner or subscribers[LP.Name]) and allPrivateMsgs or myPrivateMsgs
    for _,msg in ipairs(show) do
        if (msg.from==targetName and msg.to==LP.Name) or (msg.from==LP.Name and msg.to==targetName) then
            AddMsg(msg.from,msg.text,"private")
        end
    end
    N("خاص","فتحت محادثة مع "..targetName)
end

-- دالة رسالة - الاسم قابل للضغط لفتح خاص
local function AddMsg(sender,text,msgType)
    msgCount=msgCount+1
    local row=Instance.new("Frame",MsgScroll)
    row.Size=UDim2.new(1,0,0,0)
    row.AutomaticSize=Enum.AutomaticSize.Y
    row.BackgroundTransparency=1
    row.BorderSizePixel=0
    row.LayoutOrder=msgCount

    local nameColor=Color3.fromRGB(255,200,0)
    if msgType=="private" then nameColor=Color3.fromRGB(220,100,255) end
    if msgType=="system" then nameColor=Color3.fromRGB(100,255,150) end
    if sender==LP.Name then nameColor=Color3.fromRGB(200,240,255) end

    if msgType=="system" then
        local lbl=Instance.new("TextLabel",row)
        lbl.Size=UDim2.new(1,0,0,0);lbl.AutomaticSize=Enum.AutomaticSize.Y
        lbl.BackgroundTransparency=1;lbl.TextWrapped=true
        lbl.TextXAlignment=Enum.TextXAlignment.Left
        lbl.Font=Enum.Font.Gotham;lbl.TextSize=14;lbl.BorderSizePixel=0
        lbl.RichText=true
        lbl.Text='<font color="rgb(100,255,150)"><i>⚙️ '..text..'</i></font>'
        lbl.TextColor3=Color3.new(1,1,1)
    else
        -- الاسم كزر قابل للضغط
        local nameBtn=Instance.new("TextButton",row)
        nameBtn.Size=UDim2.new(1,0,0,0)
        nameBtn.AutomaticSize=Enum.AutomaticSize.Y
        nameBtn.BackgroundTransparency=1;nameBtn.BorderSizePixel=0
        nameBtn.Font=Enum.Font.GothamBold;nameBtn.TextSize=16
        nameBtn.TextColor3=nameColor
        nameBtn.TextXAlignment=Enum.TextXAlignment.Left
        nameBtn.RichText=true
        nameBtn.TextWrapped=true
        local prefix=msgType=="private" and "🔒 " or ""
        nameBtn.Text='<font color="rgb('..math.floor(nameColor.R*255)..','..math.floor(nameColor.G*255)..','..math.floor(nameColor.B*255)..')"><b>'..prefix..'['..sender..']:</b></font> <font color="rgb(255,255,255)">'..text..'</font>'

        if sender~=LP.Name and msgType~="private" then
            nameBtn.MouseButton1Click:Connect(function()
                OpenPrivate(sender)
                nameBtn.TextColor3=Color3.fromRGB(255,255,100)
                task.wait(0.15);nameBtn.TextColor3=nameColor
            end)
            nameBtn.MouseEnter:Connect(function() nameBtn.TextColor3=Color3.fromRGB(255,255,100) end)
            nameBtn.MouseLeave:Connect(function() nameBtn.TextColor3=nameColor end)
        end
    end

    task.wait()
    MsgScroll.CanvasPosition=Vector2.new(0,MsgLayout.AbsoluteContentSize.Y+999)
end


